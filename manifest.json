{
  "manifest_version": 3,
  "name": "YouTube Watch Later Manager",
  "version": "1.0",
  "description": "Gestisci e visualizza i tuoi video YouTube 'Watch Later' in modo più semplice.",
  "permissions": ["storage", "tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}
